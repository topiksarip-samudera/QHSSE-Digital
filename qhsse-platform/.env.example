# ===========================================
# QHSSE Platform — Environment Configuration
# ===========================================
# Copy this file to .env and fill in values

# ---------- General ----------
NODE_ENV=development
APP_NAME=QHSSE Platform
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ---------- Database (PostgreSQL) ----------
DATABASE_URL=postgresql://qhsse:qhsse_secret@localhost:5432/qhsse_db?schema=public

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- MinIO / S3 Storage ----------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=qhsse_minio
MINIO_SECRET_KEY=qhsse_minio_secret
MINIO_BUCKET=qhsse-files
MINIO_USE_SSL=false

# ---------- JWT Auth ----------
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string
JWT_REFRESH_EXPIRES_IN=7d

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:3000

# ---------- Rate Limiting ----------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ---------- Email (Phase 2+) ----------
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ---------- Logging ----------
LOG_LEVEL=debug
