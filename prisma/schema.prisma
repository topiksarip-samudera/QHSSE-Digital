  @@index([companyId])
  @@index([userId])
  @@map("sync_logs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 3 — ADVANCED INTEGRATION CENTER
// ═══════════════════════════════════════════════════════════════════════════════

model Integration {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  name        String
  type        String    // rest_api, database, sftp, graphql, webhook
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  authType    String?   @map("auth_type") // none, basic, bearer, oauth2, api_key
  credentials Json?     // Encrypted credentials
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  configs   IntegrationConfig[]
  mappings  IntegrationMapping[]
  syncJobs  IntegrationSyncJob[]

  @@index([companyId])
  @@index([type])
  @@map("integrations")
}

model IntegrationConfig {
  id            String   @id @default(cuid())
  integrationId String   @map("integration_id")
  configKey     String   @map("config_key")
  configValue   String   @map("config_value")
  createdAt     DateTime @default(now()) @map("created_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@map("integration_configs")
}

model IntegrationMapping {
  id            String   @id @default(cuid())
  integrationId String   @map("integration_id")
  sourceField   String   @map("source_field")
  targetField   String   @map("target_field")
  transform     String?  // none, uppercase, lowercase, trim, date_format
  defaultValue  String?  @map("default_value")
  createdAt     DateTime @default(now()) @map("created_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@map("integration_mappings")
}

model IntegrationSyncJob {
  id             String    @id @default(cuid())
  integrationId  String    @map("integration_id")
  companyId      String    @map("company_id")
  status         String    @default("pending") // pending, running, completed, failed
  recordsTotal   Int       @default(0) @map("records_total")
  recordsSynced  Int       @default(0) @map("records_synced")
