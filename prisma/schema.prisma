model AISettings {
  id                     String   @id @default(cuid())
  companyId              String   @unique @map("company_id")
  isEnabled              Boolean  @default(true) @map("is_enabled")
  defaultProviderId      String?  @map("default_provider_id")
  defaultModel           String?  @map("default_model")
  maxTokensPerRequest    Int      @default(4000) @map("max_tokens_per_request")
  maxTokensPerDay        Int      @default(100000) @map("max_tokens_per_day")
  maxCostPerDay          Float    @default(50.0) @map("max_cost_per_day")
  enableRag              Boolean  @default(true) @map("enable_rag")
  enableModuleConnectors Boolean  @default(true) @map("enable_module_connectors")
  enableGuardrails       Boolean  @default(true) @map("enable_guardrails")
  enableAuditLog         Boolean  @default(true) @map("enable_audit_log")
  allowedModules         String[] @map("allowed_modules") // incident, risk, audit, etc.
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("ai_settings")
}

model AIProvider {
  id              String    @id @default(cuid())
  providerKey     String    @unique @map("provider_key") // openai, anthropic, google, azure, local
  name            String
  description     String?
  baseUrl         String    @map("base_url")
  apiKeyEncrypted String    @map("api_key_encrypted") // Encrypted with app key
  authType        String    @default("bearer") @map("auth_type") // bearer, api_key, oauth
  isEnabled       Boolean   @default(true) @map("is_enabled")
  defaultModel    String?   @map("default_model")
  maxTokens       Int       @default(8000) @map("max_tokens")
  timeoutSeconds  Int       @default(60) @map("timeout_seconds")
  maxRetries      Int       @default(3) @map("max_retries")
  priority        Int       @default(10) // Lower number = higher priority
  createdBy       String    @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  models             AIProviderModel[]
  tenantSettings     AITenantProviderSetting[]
  usageLogs          AIUsageLog[]
  messages           AIMessage[]

  @@index([providerKey], map: "idx_ai_providers_provider_key")
  @@index([isEnabled], map: "idx_ai_providers_is_enabled")
  @@map("ai_providers")
}

model AIProviderModel {
  id                 String   @id @default(cuid())
  providerId         String   @map("provider_id")
  modelKey           String   @map("model_key") // gpt-4, claude-3-opus, gemini-pro
  displayName        String   @map("display_name")
  contextWindow      Int      @map("context_window")
  maxOutputTokens    Int      @map("max_output_tokens")
  costPer1kInput     Float    @map("cost_per_1k_input") // USD
  costPer1kOutput    Float    @map("cost_per_1k_output") // USD
  supportsStreaming  Boolean  @default(true) @map("supports_streaming")
  supportsFunctions  Boolean  @default(false) @map("supports_functions")
  supportsVision     Boolean  @default(false) @map("supports_vision")
  isEnabled          Boolean  @default(true) @map("is_enabled")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  provider  AIProvider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  aliases   AIModelAlias[]

  @@unique([providerId, modelKey])
  @@index([providerId], map: "idx_ai_provider_models_provider_id")
  @@index([isEnabled], map: "idx_ai_provider_models_is_enabled")
  @@map("ai_provider_models")
}

model AIModelAlias {
  id       String   @id @default(cuid())
  modelId  String   @map("model_id")
  alias    String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  model AIProviderModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId], map: "idx_ai_model_aliases_model_id")
