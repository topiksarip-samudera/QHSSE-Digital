  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  plan   Plan               @relation(fields: [planId], references: [id])
  usage  SubscriptionUsage?

  @@index([companyId])
  @@index([planId])
