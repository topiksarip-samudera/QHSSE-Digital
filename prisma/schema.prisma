  filePath   String?  @map("file_path")
  fileSize   Float?   @map("file_size")
  exportedBy String   @map("exported_by")
  createdAt  DateTime @default(now()) @map("created_at")

  run ReportRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("report_exports")
}

// ═══════════════════════════════════════════════════════════════════════════════
// OPERATIONAL MODULE 01 — RISK MANAGEMENT / HIRADC / JSA
// ═══════════════════════════════════════════════════════════════════════════════

model RiskRegister {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  siteId          String?   @map("site_id")
  title           String
  description     String?
  category        String    @default("operational") // operational, financial, strategic, compliance, reputational
  likelihood      Int       @default(1) // 1-5
  consequence     Int       @default(1) // 1-5
  riskLevel       String?   @map("risk_level") // low, medium, high, extreme — computed
  riskOwner       String?   @map("risk_owner")
  status          String    @default("open") // open, mitigated, closed, transferred
  sourceType      String?   @map("source_type") // hiradc, jsa, manual, incident
  sourceId        String?   @map("source_id")
  mitigationPlan  String?   @map("mitigation_plan")
  residualLikelihood Int?   @map("residual_likelihood")
  residualConsequence Int? @map("residual_consequence")
  residualLevel   String?   @map("residual_level")
  reviewDate      DateTime? @map("review_date")
  createdBy       String    @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([companyId])
  @@index([siteId])
  @@index([riskLevel])
  @@index([status])
  @@map("risk_registers")
}

model JsaTemplate {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  siteId      String?   @map("site_id")
  title       String
  jobTitle    String?   @map("job_title")
  department  String?
  status      String    @default("draft")
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  steps JsaStep[]

  @@index([companyId])
  @@map("jsa_templates")
}

model JsaStep {
  id              String   @id @default(cuid())
  jsaId           String   @map("jsa_id")
  stepNumber      Int      @map("step_number")
  stepDescription String   @map("step_description")
  hazard          String?
  controlMeasure  String?  @map("control_measure")
  responsiblePerson String? @map("responsible_person")
  createdAt       DateTime @default(now()) @map("created_at")

  jsa JsaTemplate @relation(fields: [jsaId], references: [id], onDelete: Cascade)

  hazards  JsaStepHazard[]
  controls JsaStepControl[]

  @@index([jsaId])
  @@map("jsa_steps")
}

model JsaStepHazard {
  id            String   @id @default(cuid())
  stepId        String   @map("step_id")
  jsaId         String   @map("jsa_id")
  companyId     String   @map("company_id")
  hazardDesc    String   @map("hazard_description")
  consequence   String?
  initialSeverity Int?   @map("initial_severity")
  initialLikelihood Int? @map("initial_likelihood")
  initialRiskScore Int?  @map("initial_risk_score")
  initialRiskLevel String? @map("initial_risk_level")
  existingControls String? @map("existing_controls")
  residualSeverity Int?  @map("residual_severity")
  residualLikelihood Int? @map("residual_likelihood")
  residualRiskScore Int? @map("residual_risk_score")
  residualRiskLevel String? @map("residual_risk_level")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  step JsaStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([stepId])
  @@map("jsa_step_hazards")
}

model JsaStepControl {
  id          String   @id @default(cuid())
  stepId      String   @map("step_id")
  hazardId    String?  @map("hazard_id")
  jsaId       String   @map("jsa_id")
  companyId   String   @map("company_id")
  controlType String   @map("control_type") // elimination, substitution, engineering, administrative, ppe
  description String
  ppeRequired String?  @map("ppe_required")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  step JsaStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([stepId])
  @@map("jsa_step_controls")
}

model RiskControl {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  riskId      String?  @map("risk_id") // linked to risk register
  name        String
  controlType String   @map("control_type") // elimination, substitution, engineering, administrative, ppe
  description String?
  ownerId     String?  @map("owner_id")
  status      String   @default("active") // active, ineffective, retired
  isCritical  Boolean  @default(false) @map("is_critical")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  effectiveness RiskControlEffectiveness[]
  verifications  CriticalControlVerification[]

  @@index([companyId])
  @@index([riskId])
  @@index([controlType])
  @@map("risk_controls")
}

model RiskControlEffectiveness {
  id          String   @id @default(cuid())
  controlId   String   @map("control_id")
  companyId   String   @map("company_id")
  rating      String   @default("effective") // effective, partially_effective, ineffective
  reviewedBy  String   @map("reviewed_by")
  reviewDate  DateTime @default(now()) @map("review_date")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  control RiskControl @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@index([controlId])
  @@map("risk_control_effectiveness")
}

model CriticalControlVerification {
  id          String    @id @default(cuid())
  controlId   String    @map("control_id")
  companyId   String    @map("company_id")
  verifiedBy  String    @map("verified_by")
  status      String    @default("pass") // pass, fail
  notes       String?
  verifiedAt  DateTime  @default(now()) @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  control RiskControl @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@index([controlId])
  @@map("critical_control_verifications")
}

model RiskActionLink {
  id         String   @id @default(cuid())
  riskId     String   @map("risk_id")
  actionId   String   @map("action_id")
  companyId  String   @map("company_id")
  actionType String   @default("mitigation") @map("action_type") // mitigation, verification, review
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([riskId])
  @@index([actionId])
  @@map("risk_action_links")
}

model RiskReviewRecord {
  id         String   @id @default(cuid())
  riskId     String   @map("risk_id")
  companyId  String   @map("company_id")
  reviewerId String   @map("reviewer_id")
  action     String   // reviewed, approved, rejected, revision_requested
  comment    String?
  oldStatus  String?  @map("old_status")
  newStatus  String   @map("new_status")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([riskId])
  @@map("risk_review_records")
}

model RiskLink {
  id            String   @id @default(cuid())
  riskId        String   @map("risk_id")
  companyId     String   @map("company_id")
  linkedModule  String   @map("linked_module") // incident, permit, audit, training, document, asset, contractor, legal, environment
  linkedRecordType String @map("linked_record_type")
  linkedRecordId String  @map("linked_record_id")
  linkType      String   @default("related") @map("link_type") // related, derived_from, leads_to
