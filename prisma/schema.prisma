  @@unique([companyId, providerId])
  @@index([companyId], map: "idx_ai_tenant_provider_settings_company_id")
  @@index([providerId], map: "idx_ai_tenant_provider_settings_provider_id")
  @@map("ai_tenant_provider_settings")
}

model AIFeatureToggle {
