// ═══════════════════════════════════════════════════════════════════════════════
// OPERATIONAL MODULE — INCIDENT MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

model IncidentSetting {
  id                  String   @id @default(cuid())
  companyId           String   @unique @map("company_id")
  requireWorkflow     Boolean  @default(true) @map("require_workflow")
  severityMatrix      Json     @map("severity_matrix") // [{ level: "low/medium/high/critical", label, color, slaHours }]
  autoAssignInvestigator Boolean @default(false) @map("auto_assign_investigator")
  defaultInvestigatorRole String? @map("default_investigator_role")
  requireAttachment   Boolean  @default(false) @map("require_attachment")
  maxReportDays       Int      @default(30) @map("max_report_days")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("incident_settings")
}

model Incident {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  number          String?   // Auto-generated from numbering core
  title           String
  description     String
  incidentDate    DateTime  @map("incident_date")
  reportedById    String    @map("reported_by_id")
  siteId          String?   @map("site_id")
  departmentId    String?   @map("department_id")
  locationId      String?   @map("location_id")
  immediateAction String?   @map("immediate_action")
  status          String    @default("draft")
  // Classification
  incidentTypeId  String?   @map("incident_type_id")
  categoryId      String?   @map("category_id")
  actualSeverity  String?   @map("actual_severity") // low, medium, high, critical
  potentialSeverity String? @map("potential_severity")
  actualConsequence    String? @map("actual_consequence")
  potentialConsequence String? @map("potential_consequence")
  isHighSeverity  Boolean   @default(false) @map("is_high_severity")
  isRepeat        Boolean   @default(false) @map("is_repeat") // draft, submitted, under_review, investigation, rca_completed, capa_in_progress, closed, cancelled
  createdBy       String    @map("created_by")
  updatedBy       String?   @map("updated_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  statusHistories IncidentStatusHistory[]
  classifications IncidentClassification[]
  impacts         IncidentImpact[]
  people          IncidentPerson[]
  injuries        IncidentInjury[]
  assets          IncidentAsset[]
  propertyDamages IncidentPropertyDamage[]
  envImpacts      IncidentEnvironmentalImpact[]
  reviewRecords   IncidentReviewRecord[]
  investigatorAssignments IncidentInvestigatorAssignment[]
  investigations  IncidentInvestigation[]
  chronologies    IncidentChronology[]
  interviews      IncidentInterview[]
  barriers        IncidentFailedBarrier[]
  findings        IncidentInvestigationFinding[]
  rootCauses      IncidentRootCause[]
  rcaReviews      IncidentRcaReview[]
  timelineEvents  IncidentTimelineEvent[]
