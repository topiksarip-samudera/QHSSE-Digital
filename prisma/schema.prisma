  companyId  String    @map("company_id")
  type       String    @default("manual") // manual, scheduled
  scope      String    @default("db") // db, files, full
  status     String    @default("pending") // pending, running, completed, failed
  fileName   String?   @map("file_name")
  fileSize   Float?    @map("file_size") // MB
  encrypted  Boolean   @default(true)
  createdBy  String    @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  @@index([companyId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("backups")
}

model BackupSchedule {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  name       String
  scope      String   @default("db") // db, files, full
  frequency  String   @default("daily") // daily, weekly, monthly
  time       String   @default("02:00") // HH:MM UTC
  retention  Int      @default(30) // days
  isActive   Boolean  @default(true) @map("is_active")
  lastRunAt  DateTime? @map("last_run_at")
  nextRunAt  DateTime? @map("next_run_at")
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([companyId])
