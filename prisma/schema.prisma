  module     String
  action     String   // create, update, delete
  recordType String   @map("record_type")
  recordId   String?  @map("record_id")
  payload    Json
  status     String   @default("queued") // queued, syncing, completed, failed, conflict
  attempts   Int      @default(0)
  error      String?
  createdAt  DateTime @default(now()) @map("created_at")
  syncedAt   DateTime? @map("synced_at")

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@map("sync_jobs")
}

model SyncConflict {
  id           String   @id @default(cuid())
  syncJobId    String   @map("sync_job_id")
  companyId    String   @map("company_id")
  serverData   Json     @map("server_data")
  clientData   Json     @map("client_data")
  resolution   String?  // keep_server, keep_client, merge
  resolvedBy   String?  @map("resolved_by")
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([syncJobId])
  @@index([companyId])
  @@map("sync_conflicts")
}

model SyncLog {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  userId    String   @map("user_id")
  action    String   // push, pull, conflict_resolve
  items     Int      @default(0)
  errors    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId])
  @@index([userId])
  @@map("sync_logs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 3 — ADVANCED INTEGRATION CENTER
// ═══════════════════════════════════════════════════════════════════════════════

model Integration {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  name        String
  type        String    // rest_api, database, sftp, graphql, webhook
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  authType    String?   @map("auth_type") // none, basic, bearer, oauth2, api_key
  credentials Json?     // Encrypted credentials
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  configs   IntegrationConfig[]
  mappings  IntegrationMapping[]
  syncJobs  IntegrationSyncJob[]

  @@index([companyId])
  @@index([type])
  @@map("integrations")
}

model IntegrationConfig {
  id            String   @id @default(cuid())
  integrationId String   @map("integration_id")
  configKey     String   @map("config_key")
  configValue   String   @map("config_value")
  createdAt     DateTime @default(now()) @map("created_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@map("integration_configs")
}

model IntegrationMapping {
  id            String   @id @default(cuid())
  integrationId String   @map("integration_id")
  sourceField   String   @map("source_field")
  targetField   String   @map("target_field")
  transform     String?  // none, uppercase, lowercase, trim, date_format
  defaultValue  String?  @map("default_value")
  createdAt     DateTime @default(now()) @map("created_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@map("integration_mappings")
}

model IntegrationSyncJob {
  id             String    @id @default(cuid())
  integrationId  String    @map("integration_id")
  companyId      String    @map("company_id")
  status         String    @default("pending") // pending, running, completed, failed
  recordsTotal   Int       @default(0) @map("records_total")
  recordsSynced  Int       @default(0) @map("records_synced")
  recordsFailed  Int       @default(0) @map("records_failed")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  integration Integration           @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  logs        IntegrationSyncLog[]
  errors      IntegrationError[]

  @@index([integrationId])
  @@index([companyId])
  @@map("integration_sync_jobs")
}

model IntegrationSyncLog {
  id         String   @id @default(cuid())
  syncJobId  String   @map("sync_job_id")
  message    String
  createdAt  DateTime @default(now()) @map("created_at")

  syncJob IntegrationSyncJob @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@index([syncJobId])
  @@map("integration_sync_logs")
}

model IntegrationError {
  id         String   @id @default(cuid())
  syncJobId  String   @map("sync_job_id")
  recordId   String?  @map("record_id")
  message    String
  stack      String?
  createdAt  DateTime @default(now()) @map("created_at")

  syncJob IntegrationSyncJob @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@index([syncJobId])
  @@map("integration_errors")
}

