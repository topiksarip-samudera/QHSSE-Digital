}

model RestoreRequest {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  backupId    String    @map("backup_id")
  reason      String?
  status      String    @default("pending") // pending, approved, rejected, running, completed, failed
  requestedBy String    @map("requested_by")
  approvedBy  String?   @map("approved_by")
  approvedAt  DateTime? @map("approved_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  logs RestoreLog[]

  @@index([companyId])
  @@index([backupId])
  @@index([status])
  @@map("restore_requests")
}

model RestoreLog {
  id         String   @id @default(cuid())
  requestId  String   @map("request_id")
  message    String
  level      String   @default("info") // info, warn, error
  createdAt  DateTime @default(now()) @map("created_at")

  request RestoreRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("restore_logs")
}

