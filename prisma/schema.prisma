  temperature      Float     @default(0.7)
  maxTokens        Int       @default(2000) @map("max_tokens")
  enableRag        Boolean   @default(false) @map("enable_rag")
  enableModuleData Boolean   @default(false) @map("enable_module_data")
  metadata         Json?
  lastMessageAt    DateTime? @map("last_message_at")
  messageCount     Int       @default(0) @map("message_count")
  totalTokens      Int       @default(0) @map("total_tokens")
  totalCost        Float     @default(0) @map("total_cost")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  workspace       AIWorkspace?      @relation(fields: [workspaceId], references: [id])
  messages        AIMessage[]
  contextRequests AIContextRequest[]

  @@index([companyId], map: "idx_ai_conversations_company_id")
  @@index([workspaceId], map: "idx_ai_conversations_workspace_id")
  @@index([ownerId], map: "idx_ai_conversations_owner_id")
  @@index([moduleKey], map: "idx_ai_conversations_module_key")
  @@index([status], map: "idx_ai_conversations_status")
  @@map("ai_conversations")
}

model AIMessage {
  id                String    @id @default(cuid())
  conversationId    String    @map("conversation_id")
  role              String    // system, user, assistant, function
  content           String    @db.Text
  model             String?
  providerId        String?   @map("provider_id")
  providerKey       String?   @map("provider_key") // openai, anthropic, etc.
  promptTokens      Int       @default(0) @map("prompt_tokens")
  completionTokens  Int       @default(0) @map("completion_tokens")
  totalTokens       Int       @default(0) @map("total_tokens")
  costEstimate      Float     @default(0) @map("cost_estimate")
  latencyMs         Int?      @map("latency_ms")
  guardrailStatus   String    @default("passed") @map("guardrail_status") // passed, warned, blocked
  guardrailViolations Json?   @map("guardrail_violations")
  functionCall      Json?     @map("function_call") // For function calling
  toolCalls         Json?     @map("tool_calls") // For tool use
  error             String?
  metadata          Json?
  createdAt         DateTime  @default(now()) @map("created_at")

  conversation AIConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  provider     AIProvider?     @relation(fields: [providerId], references: [id])
  sources      AIMessageSource[]

  @@index([conversationId], map: "idx_ai_messages_conversation_id")
  @@index([providerId], map: "idx_ai_messages_provider_id")
  @@index([role], map: "idx_ai_messages_role")
  @@index([createdAt], map: "idx_ai_messages_created_at")
  @@map("ai_messages")
}

model AIMessageSource {
  id              String   @id @default(cuid())
  messageId       String   @map("message_id")
  sourceType      String   @map("source_type") // document, module_data, web_search
  moduleKey       String?  @map("module_key") // incident, risk, audit, etc.
  recordId        String?  @map("record_id")
  documentId      String?  @map("document_id")
  chunkId         String?  @map("chunk_id")
  sourceTitle     String?  @map("source_title")
  sourceExcerpt   String?  @map("source_excerpt") @db.Text
  sourceUrl       String?  @map("source_url")
  confidenceScore Float?   @map("confidence_score")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  message  AIMessage            @relation(fields: [messageId], references: [id], onDelete: Cascade)
  document AIKnowledgeDocument? @relation(fields: [documentId], references: [id])

  @@index([messageId], map: "idx_ai_message_sources_message_id")
  @@index([sourceType], map: "idx_ai_message_sources_source_type")
  @@index([moduleKey, recordId], map: "idx_ai_message_sources_module_record")
  @@index([documentId], map: "idx_ai_message_sources_document_id")
  @@map("ai_message_sources")
}

model AIContextRequest {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  requestType    String   @map("request_type") // rag_search, module_query, web_search
  query          String   @db.Text
  filters        Json?
  topK           Int      @default(5) @map("top_k")
  minScore       Float?   @map("min_score")
  results        Json?    // Retrieved context results
  resultCount    Int      @default(0) @map("result_count")
  latencyMs      Int?     @map("latency_ms")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId], map: "idx_ai_context_requests_conversation_id")
  @@index([requestType], map: "idx_ai_context_requests_request_type")
  @@map("ai_context_requests")
}

// ─── RAG & Knowledge Base ───────────────────────────────────────────────────────

model AIKnowledgeBase {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  name        String
  description String?
  moduleKey   String?   @map("module_key") // Optional: link to specific module
  visibility  String    @default("company") // user, team, company
  embeddingModel String @default("text-embedding-ada-002") @map("embedding_model")
  chunkSize   Int       @default(1000) @map("chunk_size")
  chunkOverlap Int      @default(200) @map("chunk_overlap")
  isIndexed   Boolean   @default(false) @map("is_indexed")
  documentCount Int     @default(0) @map("document_count")
  chunkCount  Int       @default(0) @map("chunk_count")
  status      String    @default("active") // active, indexing, failed
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  documents AIKnowledgeDocument[]

  @@index([companyId], map: "idx_ai_knowledge_bases_company_id")
  @@index([moduleKey], map: "idx_ai_knowledge_bases_module_key")
  @@index([status], map: "idx_ai_knowledge_bases_status")
  @@map("ai_knowledge_bases")
}

model AIKnowledgeDocument {
  id              String    @id @default(cuid())
  knowledgeBaseId String    @map("knowledge_base_id")
  companyId       String    @map("company_id")
  title           String
  filename        String?
  mimeType        String?   @map("mime_type")
  fileSize        Int?      @map("file_size")
  fileUrl         String?   @map("file_url")
  content         String?   @db.Text
  sourceType      String    @default("upload") @map("source_type") // upload, url, module_sync
  sourceUrl       String?   @map("source_url")
  moduleKey       String?   @map("module_key")
  recordId        String?   @map("record_id")
  isIndexed       Boolean   @default(false) @map("is_indexed")
  chunkCount      Int       @default(0) @map("chunk_count")
  metadata        Json?
  uploadedBy      String    @map("uploaded_by")
  indexedAt       DateTime? @map("indexed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  knowledgeBase AIKnowledgeBase     @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks        AIDocumentChunk[]
  messageSources AIMessageSource[]

  @@index([knowledgeBaseId], map: "idx_ai_knowledge_documents_kb_id")
  @@index([companyId], map: "idx_ai_knowledge_documents_company_id")
  @@index([isIndexed], map: "idx_ai_knowledge_documents_is_indexed")
  @@index([moduleKey, recordId], map: "idx_ai_knowledge_documents_module_record")
  @@map("ai_knowledge_documents")
}

model AIDocumentChunk {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  chunkIndex Int      @map("chunk_index")
  content    String   @db.Text
  startChar  Int      @map("start_char")
  endChar    Int      @map("end_char")
  tokenCount Int      @map("token_count")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  document AIKnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  vectors  AIVectorIndex[]

  @@unique([documentId, chunkIndex])
  @@index([documentId], map: "idx_ai_document_chunks_document_id")
  @@map("ai_document_chunks")
}

model AIVectorIndex {
  id         String   @id @default(cuid())
  chunkId    String   @map("chunk_id")
  embedding  String   @db.Text // JSON array or binary representation
  dimension  Int      @default(1536) // OpenAI ada-002: 1536, others vary
  model      String   @default("text-embedding-ada-002")
  createdAt  DateTime @default(now()) @map("created_at")

  chunk AIDocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@unique([chunkId])
  @@index([chunkId], map: "idx_ai_vector_indexes_chunk_id")
  @@map("ai_vector_indexes")
}

// ─── Module Connectors ──────────────────────────────────────────────────────────

model AIModuleConnector {
  id          String   @id @default(cuid())
  moduleKey   String   @unique @map("module_key") // incident, risk, audit, etc.
  name        String
  description String?
  tableName   String   @map("table_name")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  maxRecords  Int      @default(100) @map("max_records") // Safety limit
  config      Json?    // Module-specific configuration
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  fields AIModuleConnectorField[]

  @@index([moduleKey], map: "idx_ai_module_connectors_module_key")
  @@index([isEnabled], map: "idx_ai_module_connectors_is_enabled")
  @@map("ai_module_connectors")
}

model AIModuleConnectorField {
  id          String   @id @default(cuid())
  connectorId String   @map("connector_id")
  fieldKey    String   @map("field_key")
  fieldName   String   @map("field_name")
  fieldType   String   @map("field_type") // string, number, date, boolean, enum
  isExposed   Boolean  @default(true) @map("is_exposed") // Can AI access this field?
  isSensitive Boolean  @default(false) @map("is_sensitive") // Should be masked/redacted?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  connector AIModuleConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@unique([connectorId, fieldKey])
  @@index([connectorId], map: "idx_ai_module_connector_fields_connector_id")
  @@map("ai_module_connector_fields")
}

// ─── Prompts & Skills ───────────────────────────────────────────────────────────

model AIPromptTemplate {
  id          String   @id @default(cuid())
  companyId   String?  @map("company_id") // NULL = system template
  key         String   @unique
  name        String
  description String?
  category    String? // analysis, draft, summary, review, etc.
  template    String   @db.Text
  variables   Json? // Variables used in template
  isSystem    Boolean  @default(false) @map("is_system")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  useCount    Int      @default(0) @map("use_count")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([companyId], map: "idx_ai_prompt_templates_company_id")
  @@index([category], map: "idx_ai_prompt_templates_category")
  @@index([isEnabled], map: "idx_ai_prompt_templates_is_enabled")
  @@map("ai_prompt_templates")
}

model AISkill {
  id          String   @id @default(cuid())
  skillKey    String   @unique @map("skill_key") // incident_rca, risk_assessment, jsa_draft, etc.
  name        String
  description String?
  category    String? // incident, risk, audit, permit, compliance, report
  moduleKey   String?  @map("module_key")
  promptTemplate String @db.Text @map("prompt_template")
  systemPrompt String? @db.Text @map("system_prompt")
  requiredPermissions String[] @map("required_permissions")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  config      Json? // Skill-specific configuration
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  runs AISkillRun[]

  @@index([skillKey], map: "idx_ai_skills_skill_key")
  @@index([category], map: "idx_ai_skills_category")
  @@index([moduleKey], map: "idx_ai_skills_module_key")
  @@index([isEnabled], map: "idx_ai_skills_is_enabled")
  @@map("ai_skills")
}

model AISkillRun {
  id          String   @id @default(cuid())
  skillId     String   @map("skill_id")
  companyId   String   @map("company_id")
  userId      String   @map("user_id")
  moduleKey   String?  @map("module_key")
  recordId    String?  @map("record_id")
  input       Json
  output      Json?
  model       String?
  promptTokens Int     @default(0) @map("prompt_tokens")
  completionTokens Int @default(0) @map("completion_tokens")
  totalTokens Int     @default(0) @map("total_tokens")
  cost        Float    @default(0)
  latencyMs   Int?     @map("latency_ms")
  status      String   @default("pending") // pending, running, completed, failed
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  skill AISkill @relation(fields: [skillId], references: [id])

  @@index([skillId], map: "idx_ai_skill_runs_skill_id")
  @@index([companyId], map: "idx_ai_skill_runs_company_id")
  @@index([userId], map: "idx_ai_skill_runs_user_id")
  @@index([status], map: "idx_ai_skill_runs_status")
  @@index([createdAt], map: "idx_ai_skill_runs_created_at")
  @@map("ai_skill_runs")
}

model AIWorkflowTemplate {
  id          String   @id @default(cuid())
  companyId   String?  @map("company_id") // NULL = system template
  name        String
  description String?
  moduleKey   String?  @map("module_key")
  trigger     String // manual, schedule, event
  steps       Json // Workflow steps configuration
  isEnabled   Boolean  @default(true) @map("is_enabled")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([companyId], map: "idx_ai_workflow_templates_company_id")
  @@index([moduleKey], map: "idx_ai_workflow_templates_module_key")
  @@map("ai_workflow_templates")
}

// ─── Usage & Cost Tracking ──────────────────────────────────────────────────────

model AIUsageLog {
  id               String   @id @default(cuid())
  companyId        String   @map("company_id")
  userId           String   @map("user_id")
  providerId       String?  @map("provider_id")
  providerKey      String?  @map("provider_key")
  model            String?
  featureKey       String   @map("feature_key") // chat, rag, skill_incident_rca, etc.
  moduleKey        String?  @map("module_key")
  conversationId   String?  @map("conversation_id")
  messageId        String?  @map("message_id")
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  cost             Float    @default(0)
  latencyMs        Int?     @map("latency_ms")
  status           String   @default("success") // success, error, timeout
  error            String?
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")

  provider AIProvider? @relation(fields: [providerId], references: [id])

  @@index([companyId], map: "idx_ai_usage_logs_company_id")
  @@index([userId], map: "idx_ai_usage_logs_user_id")
  @@index([providerId], map: "idx_ai_usage_logs_provider_id")
  @@index([featureKey], map: "idx_ai_usage_logs_feature_key")
  @@index([createdAt], map: "idx_ai_usage_logs_created_at")
  @@map("ai_usage_logs")
}

model AICostLog {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  date        DateTime @db.Date
  providerKey String   @map("provider_key")
  model       String?
  totalTokens Int      @map("total_tokens")
  totalCost   Float    @map("total_cost")
  requestCount Int     @default(0) @map("request_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([companyId, date, providerKey, model])
  @@index([companyId], map: "idx_ai_cost_logs_company_id")
  @@index([date], map: "idx_ai_cost_logs_date")
  @@map("ai_cost_logs")
}

model AIRateLimit {
  id              String   @id @default(cuid())
  companyId       String?  @map("company_id") // NULL = system default
  userId          String?  @map("user_id") // NULL = applies to all users in company
  featureKey      String?  @map("feature_key") // NULL = applies to all features
  maxRequestsPerMinute Int? @map("max_requests_per_minute")
  maxRequestsPerHour Int?   @map("max_requests_per_hour")
  maxRequestsPerDay Int?    @map("max_requests_per_day")
  maxTokensPerDay Int?      @map("max_tokens_per_day")
  maxCostPerDay   Float?    @map("max_cost_per_day")
  isEnabled       Boolean   @default(true) @map("is_enabled")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([companyId], map: "idx_ai_rate_limits_company_id")
  @@index([userId], map: "idx_ai_rate_limits_user_id")
  @@map("ai_rate_limits")
}

model AIAdminControl {
  id          String   @id @default(cuid())
  companyId   String   @unique @map("company_id")
  allowUserPrompts Boolean @default(true) @map("allow_user_prompts")
  allowDocumentUpload Boolean @default(true) @map("allow_document_upload")
  allowModuleData Boolean @default(true) @map("allow_module_data")
  allowExport Boolean  @default(true) @map("allow_export")
  requireApproval Boolean @default(false) @map("require_approval") // For certain AI actions
  blockedKeywords String[] @map("blocked_keywords")
  allowedDomains String[] @map("allowed_domains")
  config      Json?
  updatedBy   String   @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("ai_admin_controls")
}

model AIAuditLog {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  userId      String   @map("user_id")
  action      String // conversation_created, message_sent, document_uploaded, skill_executed, etc.
  resourceType String  @map("resource_type") // conversation, message, document, skill, etc.
  resourceId  String?  @map("resource_id")
  details     Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([companyId], map: "idx_ai_audit_logs_company_id")
  @@index([userId], map: "idx_ai_audit_logs_user_id")
  @@index([action], map: "idx_ai_audit_logs_action")
  @@index([createdAt], map: "idx_ai_audit_logs_created_at")
  @@map("ai_audit_logs")
}
