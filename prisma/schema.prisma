}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 2 — COLLABORATION & COMMENT THREAD
// ═══════════════════════════════════════════════════════════════════════════════

model Comment {
  id         String    @id @default(cuid())
  companyId  String    @map("company_id")
  module     String    // target module (e.g. action, incident, workflow)
  recordType String    @map("record_type")
  recordId   String    @map("record_id")
  parentId   String?   @map("parent_id") // null = top-level, set = reply
  userId     String    @map("user_id")
  content    String
  isInternal Boolean   @default(false) @map("is_internal")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  user        User              @relation(fields: [userId], references: [id])
  parent      Comment?          @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[]         @relation("CommentReplies")
  mentions    CommentMention[]
  attachments CommentAttachment[]

  @@index([companyId])
  @@index([module, recordType, recordId])
  @@index([parentId])
  @@index([userId])
  @@map("comments")
}

model CommentMention {
  id        String   @id @default(cuid())
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([userId])
  @@map("comment_mentions")
}

model CommentAttachment {
  id           String   @id @default(cuid())
  commentId    String   @map("comment_id")
  attachmentId String   @map("attachment_id")
  createdAt    DateTime @default(now()) @map("created_at")

  comment    Comment    @relation(fields: [commentId], references: [id], onDelete: Cascade)
  attachment Attachment @relation(fields: [attachmentId], references: [id])

  @@index([commentId])
  @@map("comment_attachments")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 3 — SSO / SINGLE SIGN-ON
// ═══════════════════════════════════════════════════════════════════════════════

model SsoProvider {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  name        String
  provider    String    // oidc, saml, google, azure, okta, keycloak
  isActive    Boolean   @default(true) @map("is_active")
  config      Json      // client_id, client_secret, issuer_url, endpoints, certs, etc.
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  mappings SsoMapping[]
  logs     SsoLoginLog[]

  @@index([companyId])
  @@index([provider])
  @@index([isActive])
  @@map("sso_providers")
}

model SsoMapping {
  id            String   @id @default(cuid())
  providerId    String   @map("provider_id")
  claimPath     String   @map("claim_path") // e.g. "groups", "roles", "department"
  claimValue    String   @map("claim_value") // value from SSO claim
  targetRoleId  String?  @map("target_role_id") // mapped local role
  targetSiteId  String?  @map("target_site_id")
  autoProvision Boolean  @default(false) @map("auto_provision")
  createdAt     DateTime @default(now()) @map("created_at")

  provider SsoProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("sso_mappings")
}

model SsoLoginLog {
  id          String   @id @default(cuid())
  providerId  String   @map("provider_id")
  companyId   String   @map("company_id")
  email       String
  status      String   // success, failed, blocked
  ipAddress   String?  @map("ip_address")
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")

  provider SsoProvider @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([companyId])
  @@index([email])
  @@map("sso_login_logs")
}

model IdentityProviderConfig {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  providerId  String?  @map("provider_id")
  configKey   String   @map("config_key")
  configValue String   @map("config_value")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([companyId, configKey])
  @@index([companyId])
  @@index([providerId])
  @@map("identity_provider_configs")
}

