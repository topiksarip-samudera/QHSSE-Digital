  @@index([module, recordId])
  @@index([roleId])
  @@index([userId])
  @@map("record_permissions")
}

model DataMaskingRule {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  module    String
  field     String
  maskType  String   @map("mask_type") // full, partial, regex, credit_card, email
  pattern   String   // Regex pattern to apply
  roles     String[] // Roles that see unmasked
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId])
  @@index([module, field])
  @@map("data_masking_rules")
}

model TemporaryAccessGrant {
  id         String    @id @default(cuid())
  companyId  String    @map("company_id")
  userId     String    @map("user_id")
  module     String
  recordId   String?   @map("record_id")
  access     String    @default("read") // read, write
  reason     String?
  grantedBy  String    @map("granted_by")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([companyId])
  @@index([userId])
  @@index([expiresAt])
  @@map("temporary_access_grants")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 3 — SUBSCRIPTION, BILLING & PACKAGE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

model Plan {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float    @default(0)
  currency    String   @default("USD")
  interval    String   @default("monthly") // monthly, yearly
  maxUsers    Int?     @map("max_users")
  maxSites    Int?     @map("max_sites")
  maxStorage  Float?   @map("max_storage") // GB
  trialDays   Int      @default(0) @map("trial_days")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  features     PlanFeature[]
  subscriptions Subscription[]

  @@map("plans")
}

model PlanFeature {
  id        String   @id @default(cuid())
  planId    String   @map("plan_id")
  code      String
  name      String
  value     String?  // e.g. "100", "true", "unlimited"
  createdAt DateTime @default(now()) @map("created_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("plan_features")
}

model Subscription {
  id           String    @id @default(cuid())
  companyId    String    @unique @map("company_id")
  planId       String    @map("plan_id")
  status       String    @default("trial") // trial, active, grace, cancelled, expired
  startedAt    DateTime  @default(now()) @map("started_at")
  expiresAt    DateTime? @map("expires_at")
  trialEndsAt  DateTime? @map("trial_ends_at")
  graceEndsAt  DateTime? @map("grace_ends_at")
  cancelledAt  DateTime? @map("cancelled_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  plan   Plan               @relation(fields: [planId], references: [id])
  usage  SubscriptionUsage?

  @@index([companyId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

model SubscriptionUsage {
  id             String   @id @default(cuid())
  subscriptionId String   @unique @map("subscription_id")
  users          Int      @default(0)
  sites          Int      @default(0)
  storageMb      Float    @default(0) @map("storage_mb")
  apiCalls       Int      @default(0) @map("api_calls")
  aiCalls        Int      @default(0) @map("ai_calls")
  updatedAt      DateTime @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_usage")
}

model Invoice {
  id           String    @id @default(cuid())
  companyId    String    @map("company_id")
  subscriptionId String  @map("subscription_id")
  number       String
  amount       Float
  status       String    @default("pending") // pending, paid, overdue, cancelled
  dueDate      DateTime  @map("due_date")
  paidAt       DateTime? @map("paid_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([companyId])
  @@index([subscriptionId])
  @@map("invoices")
}

model Payment {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  invoiceId  String?  @map("invoice_id")
  amount     Float
  method     String   @default("manual") // manual, bank_transfer, credit_card
  status     String   @default("completed")
  reference  String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([companyId])
  @@index([invoiceId])
  @@map("payments")
}

model BillingLog {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  action    String   // plan_change, trial_start, trial_end, payment, invoice, grace_enter
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId])
  @@map("billing_logs")
}

// ═══════════════════════════════════════════════════════════════════════════════
