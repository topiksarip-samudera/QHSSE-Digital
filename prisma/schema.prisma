// ═══════════════════════════════════════════════════════════════════════════════
// OPERATIONAL MODULE — INCIDENT MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

model IncidentSetting {
  id                  String   @id @default(cuid())
  companyId           String   @unique @map("company_id")
  requireWorkflow     Boolean  @default(true) @map("require_workflow")
  severityMatrix      Json     @map("severity_matrix") // [{ level: "low/medium/high/critical", label, color, slaHours }]
  autoAssignInvestigator Boolean @default(false) @map("auto_assign_investigator")
  defaultInvestigatorRole String? @map("default_investigator_role")
  requireAttachment   Boolean  @default(false) @map("require_attachment")
  maxReportDays       Int      @default(30) @map("max_report_days")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("incident_settings")
}

model Incident {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  number          String?   // Auto-generated from numbering core
  title           String
  description     String
  incidentDate    DateTime  @map("incident_date")
  reportedById    String    @map("reported_by_id")
  siteId          String?   @map("site_id")
  departmentId    String?   @map("department_id")
  locationId      String?   @map("location_id")
  immediateAction String?   @map("immediate_action")
  status          String    @default("draft")
  // Classification
  incidentTypeId  String?   @map("incident_type_id")
  categoryId      String?   @map("category_id")
  actualSeverity  String?   @map("actual_severity") // low, medium, high, critical
  potentialSeverity String? @map("potential_severity")
  actualConsequence    String? @map("actual_consequence")
  potentialConsequence String? @map("potential_consequence")
  isHighSeverity  Boolean   @default(false) @map("is_high_severity")
  isRepeat        Boolean   @default(false) @map("is_repeat") // draft, submitted, under_review, investigation, rca_completed, capa_in_progress, closed, cancelled
  createdBy       String    @map("created_by")
  updatedBy       String?   @map("updated_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  statusHistories IncidentStatusHistory[]
  classifications IncidentClassification[]
  impacts         IncidentImpact[]
  people          IncidentPerson[]
  injuries        IncidentInjury[]
  assets          IncidentAsset[]
  propertyDamages IncidentPropertyDamage[]
  envImpacts      IncidentEnvironmentalImpact[]
  reviewRecords   IncidentReviewRecord[]
  investigatorAssignments IncidentInvestigatorAssignment[]
  investigations  IncidentInvestigation[]
  chronologies    IncidentChronology[]
  interviews      IncidentInterview[]
  barriers        IncidentFailedBarrier[]
  findings        IncidentInvestigationFinding[]
  rootCauses      IncidentRootCause[]
  rcaReviews      IncidentRcaReview[]
  timelineEvents  IncidentTimelineEvent[]
  lessonsLearned  IncidentLessonsLearned?

  @@index([companyId])
  @@index([siteId])
  @@index([status])
  @@index([incidentDate])
  @@map("incidents")
}

model IncidentStatusHistory {
  id         String   @id @default(cuid())
  incidentId String   @map("incident_id")
  companyId  String   @map("company_id")
  oldStatus  String?  @map("old_status")
  newStatus  String   @map("new_status")
  changedBy  String   @map("changed_by")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("incident_status_histories")
}

model IncidentClassification {
  id             String   @id @default(cuid())
  incidentId     String   @map("incident_id")
  companyId      String   @map("company_id")
  classifiedBy   String   @map("classified_by")
  reviewedBy     String?  @map("reviewed_by")
  reviewedAt     DateTime? @map("reviewed_at")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("incident_classifications")
}

model IncidentImpact {
  id          String   @id @default(cuid())
  incidentId  String   @map("incident_id")
  companyId   String   @map("company_id")
  impactType  String   @map("impact_type") // people, environment, asset, security, quality, reputation, legal
  severity    String?  // low, medium, high, critical
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("incident_impacts")
}

model IncidentRepeatLink {
  id               String   @id @default(cuid())
  incidentId       String   @map("incident_id")
  relatedIncidentId String  @map("related_incident_id")
  companyId        String   @map("company_id")
  linkType         String   @default("repeat") @map("link_type") // repeat, related, consequence
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([incidentId])
  @@index([relatedIncidentId])
  @@map("incident_repeat_links")
}

model IncidentPerson {
  id         String   @id @default(cuid())
  incidentId String   @map("incident_id")
  companyId  String   @map("company_id")
  personType String   @map("person_type") // injured, involved, witness, contractor
  userId     String?  @map("user_id") // internal user reference
  fullName   String?  @map("full_name") // free text for external
  role       String?  // operator, supervisor, visitor, contractor, etc.
  department String?
  contactInfo String? @map("contact_info")
  statement  String?  // witness statement
  createdAt  DateTime @default(now()) @map("created_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  injuries IncidentInjury[]

  @@index([incidentId])
  @@index([companyId])
  @@map("incident_people")
}

model IncidentInjury {
  id              String   @id @default(cuid())
  incidentId      String   @map("incident_id")
  personId        String   @map("person_id")
  companyId       String   @map("company_id")
  injuryTypeId    String?  @map("injury_type_id") // master data ref
  bodyPart        String?  @map("body_part")
